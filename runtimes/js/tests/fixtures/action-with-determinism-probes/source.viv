// Actions probing random callsites: a chance-gated condition and an embargo whose ID is generated via `randomID()`

action gamble:
    roles:
        @actor:
            as: initiator
    conditions:
        50%


action announce:
    roles:
        @speaker:
            as: initiator
        @listener:
            as: recipient
    embargoes:
        embargo:
            location: here
            time: forever
