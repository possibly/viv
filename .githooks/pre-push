#!/usr/bin/env bash
# .githooks/pre-push -- run preflight sync checks before pushing
#
# Rejects the push if `make preflight` fails. This catches cross-component
# inconsistencies before they reach CI (e.g., compiler version bumped
# without updating plugin `compilerVersion` pins)
#
# To enable, run once per clone:
#   git config core.hooksPath .githooks
#
# Bypass with `git push --no-verify` when a push genuinely needs to skip
# this check.

set -euo pipefail

# Skip preflight for tag-only pushes and deletions. Tags are cut from commits
# that have already passed preflight (via a prior push) and CI, so rerunning
# the multi-minute suite would only stall the release. Deletions remove refs
# without introducing new code, so there's nothing for preflight to validate.
all_skippable=true
while read -r local_ref local_sha _remote_ref _remote_sha; do
    if [[ "$local_ref" == refs/tags/* ]] || [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi
    all_skippable=false
done
if [ "$all_skippable" = true ]; then
    echo "Skipping preflight (tag push and/or deletion)"
    exit 0
fi

cd "$(git rev-parse --show-toplevel)"
make preflight
